campaign-state*.json
conversation-history*.json
game-log.json

# Backups
*.backup*
*-backup-*
*.pre-rollback*
*.corrupted

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Generated/built files
dist/
build/
*.bundle.js

# Logs
*.log
server.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Campaign-specific sensitive data
campaigns/*/conversation-history*.json
campaigns/*/campaign-state*.json
campaigns/*/*.db
campaigns/*/json-backup/

# Character portraits (potentially copyrighted)
*.png
*.jpg
*.jpeg
*.gif

# Search indices (generated)
SEARCH_INDEX.json
campaigns/*/SEARCH_INDEX.json

# Test databases
test-*.db
ecosystem.config.js

# Archive folder (old backups and dead code)
_archive/
_backup*/
*-backup/

# Combat state (runtime state, not config)
campaigns/*/combat-state.json

# Built UI assets (regenerated on build)
ui/dist/
campaigns/*/svelte-dist/assets/
__pycache__/
*.pyc
